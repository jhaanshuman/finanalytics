# Database
DB_PATH=./database/finanalytics.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3001
NODE_ENV=development

# OAuth (for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here

# AI (for production)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Cloud Sync (optional)
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_URL=
CLOUD_SYNC_API_KEY=

# License Server (for production)
LICENSE_SERVER_URL=
LICENSE_SERVER_KEY=
